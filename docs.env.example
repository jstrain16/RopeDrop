# Supabase or Postgres connection string
DATABASE_URL=postgres://user:password@host:5432/dbname

# Shared secret for cron-triggered routes (/api/internal/sync, /api/internal/process-pending)
CRON_SECRET=replace-me

# Development user id used by the mobile app and tests
DEMO_USER_ID=00000000-0000-0000-0000-000000000000

# Base URL for API (used by the mobile app config)
API_BASE_URL=http://localhost:3000

